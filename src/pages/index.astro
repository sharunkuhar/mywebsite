---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Sharun Kuhar';
const description = 'My personal website.';
const permalink = Astro.site?.href;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description} permalink={permalink}>
	<div class="home-container">
		<div class="home-copy">
			<h1>Simulating the Future<br />of Human Health.</h1>
			<p class="subtitle">Computational Fluid Dynamics · Digital Twins · Bio-Medical Engineering</p>
		</div>

		<div class="hero-image-container">
			<picture>
				<source
					srcset={`${base}assets/home-illustration.webp`}
					media="(min-width: 600px)"
				/>
				<img
					class="hero-image"
					alt="Illustration of person reading a book"
					src={`${base}assets/home-illustration-small.webp`}
					width="550"
					height="466"
				/>
			</picture>
			<p class="caption">Illustrations by <a href="https://icons8.com/illustrations" target="_blank" rel="noopener">Icons 8</a></p>
		</div>
	</div>
</BaseLayout>

<style>
	.home-container {
		align-items: center;
		display: flex;
		flex: 1;
		justify-content: center;
		margin: 2em 0;
		min-height: 400px;
	}

	.home-copy {
		flex: 1;
		padding: 0 1em;
	}

	.home-copy h1 {
		font-weight: 700;
		margin-bottom: 0.5em;
		line-height: 1.3;
	}

	.home-copy .subtitle {
		font-size: 1.2em;
		color: var(--text-secondary);
		margin-top: 0;
	}

	.hero-image-container {
		margin: 0 1em;
		text-align: center;
	}

	.hero-image-container picture {
		display: block;
		min-height: 250px;
	}

	.hero-image {
		width: 100%;
		max-width: 550px;
		margin-bottom: 1em;
	}

	@media (max-width: 1200px) {
		p {
			font-size: 1.2em;
		}

		.hero-image {
			max-width: 400px;
		}
	}

	.caption {
		font-size: 0.8rem;
		font-style: italic;
		color: var(--text-secondary);
		text-align: right;
		margin-top: 0;
	}

	@media (max-width: 800px) {
		.home-container {
			flex-direction: column;
		}

		.home-copy {
			flex: 0;
			padding-bottom: 2em;
			text-align: center;
		}
	}
</style>