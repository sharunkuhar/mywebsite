		venue: 'APS Division of Fluid Dynamics',
		link: 'https://meetings.aps.org/Meeting/DFD21/Session/T15.7',
	},
	{
		year: 2019,
		title: 'Linear Stability Analysis of Two-Dimensional Flow Past a Square Cylinder at Different Blockage Ratios',
		authors: 'S. Kuhar and Arun K. Saha',
