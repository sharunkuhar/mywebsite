---

<BaseLayout title={title} description={description} permalink={permalink} current="conferences">
	<div class="pub-container">
		<h1>Conferences</h1>

		<ul class="pub-list">
			{conferences.map((c) => (
				<li class="pub-entry">
					<span class="pub-year">{c.year}</span>
					<div class="pub-body">
						{c.link ? (
							<a href={c.link} target="_blank" rel="noopener" class="pub-title">{c.title}</a>
						) : (
							<span class="pub-title">{c.title}</span>
						)}
						<div class="pub-meta">
							{c.authors}<br /><em>{c.venue}</em>
						</div>
					</div>
				</li>
			))}
		</ul>
	</div>
</BaseLayout>

<style>
	.pub-container {
		margin: 2em auto;
		max-width: 48em;
		padding: 0 1em;
	}

	.pub-list {
		list-style: none;
		padding-left: 0;
		margin: 0;
		font-size: 1rem;
	}

	.pub-entry {
		display: flex;
		align-items: baseline;
		gap: 1rem;
		padding: 0.7rem 0;
		margin: 0;
		border-bottom: 1px solid rgba(128, 128, 128, 0.12);
		line-height: 1.4;
	}

	.pub-entry:last-child {
		border-bottom: none;
	}

	.pub-year {
		flex-shrink: 0;
		min-width: 3rem;
		font-size: 0.85rem;
		color: var(--text-secondary);
		font-variant-numeric: tabular-nums;
		opacity: 0.7;
	}

	.pub-body {
		flex: 1;
		min-width: 0;
	}

	.pub-title {
		display: block;
		font-size: 1rem;
		font-weight: 600;
		color: var(--text-main);
		text-decoration: none;
		line-height: 1.4;
	}

	a.pub-title:hover {
		color: var(--primary-color);
		text-decoration: underline;
	}

	.pub-meta {
		font-size: 0.82rem;
		color: var(--text-secondary);
		margin-top: 0.2rem;
		line-height: 1.45;
	}
</style>
