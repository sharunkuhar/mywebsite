	},
	{
		year: 2023,
		title: 'StomachSim: An in-silico simulator of gastric biomechanics with application to pyloroplasty',
		authors: 'S. Kuhar, J. H. Seo, P. J. Pasricha, and R. Mittal',
		venue: 'American Physiology Summit',
